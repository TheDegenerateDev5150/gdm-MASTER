<!DOCTYPE node PUBLIC "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN" "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">
<node name="/org/gnome/DisplayManager/RemoteDisplayFactory">
  <!--
      org.gnome.DisplayManager.RemoteDisplayFactory:
      @short_description: Remote display factory

      The remote display factory is an interface used for creating headless
      login greeter sessions or headless user sessions.
  -->
  <interface name="org.gnome.DisplayManager.RemoteDisplayFactory">
    <!--
        CreateRemoteDisplay:
        @properties: Options

        Create a headless greeter session.

        Available options:

        * ``remote-id`` (``o``)

          A required, globally unique identifier to be associated with the
          created remote display. It will exposed as a ``RemoteId`` property on
          the created :ref:`org.gnome.DisplayManager.RemoteDisplay`.
          Note that while the ID is formatted as a D-Bus object path, no actual
          D-Bus object is exposed at this path.

        * ``hostname`` (``s``)

          An optional hostname of the remote connection associated with the 
          to-be-created remote display.
    -->
    <method name="CreateRemoteDisplay">
      <arg name="properties" direction="in" type="a{sv}"/>
    </method>

    <!--
        CreateUserDisplay:
        @user: A username

        Creates a headles graphical session for the username specified by @user.

        If there is currently an active graphical session (remote or local),
        this method will fail. On success, a new
        :ref:`org.gnome.DisplayManager.RemoteDisplay` will be created.
    -->
    <method name="CreateUserDisplay">
      <arg name="user" direction="in" type="s"/>
    </method>

    <!--
        DestroyUserDisplay:
        @user: A username

        Destroys a headless graphical session of the username specified by @user.
    -->
    <method name="DestroyUserDisplay">
      <arg name="user" direction="in" type="s"/>
    </method>
  </interface>
</node>
